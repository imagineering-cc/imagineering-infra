# Encrypt with: sops -e -i secrets.yaml
# View with:    sops -d secrets.yaml

# Firebase project for Bearer JWT verification (mobile auth).
# Reusing downstream's project — same user, same auth surface.
firebase_project_id: "downstream-181e2"

# Firebase service account JSON, base64-encoded.
# Generate via: base64 -w0 < firebase-service-account.json
firebase_service_account_base64: "BASE64_ENCODED_SA_JSON"

# Long-lived OAuth token for spawning `claude -p` subprocesses inside
# familiars-server. Generate once via `claude setup-token` on a machine
# with `claude` logged in. Token is portable cross-machine, valid 1 year.
# Phase 0 doesn't use this (no agents yet); set it now to skip a step
# when Phase 1 ships, or leave blank for now.
claude_code_oauth_token: "GENERATE_WITH_claude_setup_token"
