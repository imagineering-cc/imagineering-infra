# Lugh — trickster historian pen pal
# Copy to secrets.yaml, fill in values, encrypt with: sops -e -i lugh/secrets.yaml

# ── Auth ──────────────────────────────────────────────────────────
# Preferred: run `claude setup-token` locally → 1-year OAuth token
claude_code_oauth_token: ""
# GitHub PAT (scopes: repo, issues, pull requests, read:org)
gh_token: ""

# ── Identity ──────────────────────────────────────────────────────
agent_name: "Lugh"
my_email: "lughsamildanach5@gmail.com"
peer_email: "lowellcuchulainn@gmail.com"
owner_email: ""
cc_email: ""

# ── IMAP ──────────────────────────────────────────────────────────
imap_host: "imap.gmail.com"
imap_port: "993"
imap_user: "lughsamildanach5@gmail.com"
imap_pass: ""

# ── SMTP (entrypoint generates msmtprc from these) ───────────────
smtp_host: "smtp.gmail.com"
smtp_port: "587"

# ── Git identity ──────────────────────────────────────────────────
git_user_name: "Lugh"
git_user_email: ""

# ── Repos ─────────────────────────────────────────────────────────
journal_repo: ""
archive_repo: ""

# ── Security ──────────────────────────────────────────────────────
# Comma-separated allowlist. Fail-closed: empty = all rejected.
allowed_senders: "lowellcuchulainn@gmail.com"

# ── Behavior ──────────────────────────────────────────────────────
send_first: "true"
poll_interval: "120"
model: "claude-sonnet-4-6"
max_turns: "25"
weekly_turn_quota: "500"
quota_reset_day: "4"
quota_reset_hour_utc: "6"
max_retries_per_message: "2"
report_every_n: "10"

# ── Evolution ─────────────────────────────────────────────────────
evolution_probability: "10"
evolution_max_turns: "3"

# ── Proactive outreach ────────────────────────────────────────────
initiative_probability: "5"
initiative_max_turns: "8"
initiative_cooldown_hours: "24"
