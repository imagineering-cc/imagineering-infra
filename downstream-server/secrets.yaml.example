# downstream-server Configuration
# Copy to secrets.yaml and encrypt with: sops -e -i secrets.yaml

# TMDB (themoviedb.org) — content discovery and metadata.
# Get from https://www.themoviedb.org/settings/api
tmdb_api_key:

# OMDB (omdbapi.com) — ratings aggregation.
# Get from https://www.omdbapi.com/apikey.aspx
omdb_api_key:

# Firebase — Bearer JWT verification for mobile clients.
# project_id is the Firebase project ID (e.g. downstream-181e2).
firebase_project_id:

# Service account JSON, base64-encoded.
# Generate from Firebase Console → Project Settings → Service Accounts →
# Generate new private key, then: base64 -i path/to/service-account.json
firebase_service_account_base64:

# Long-lived API key used by the CLI (Pi processor) to authenticate
# server-to-server calls. Generate with: openssl rand -hex 32
downstream_api_key:
