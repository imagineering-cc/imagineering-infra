# LiveKit Server — self-hosted SFU
# Copy to secrets.yaml and encrypt with: sops -e -i secrets.yaml

# API credentials (generate with: livekit-cli create-key)
# These must match what agents and clients use to connect.
livekit_api_key: "APIxxxxxxxxxxxxxxx"
livekit_api_secret: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# External IP of the VPS (OCI internal IP is different from public IP)
# Used in livekit.yaml for rtc.node_ip
external_ip: "149.118.69.221"
