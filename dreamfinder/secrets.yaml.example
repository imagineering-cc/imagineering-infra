# Dreamfinder — Signal bot for project management
# Copy to secrets.yaml and encrypt with: sops -e -i secrets.yaml

# Anthropic API key for Claude
anthropic_api_key: ""

# Signal — bot's registered phone number (with country code)
signal_phone_number: "+1234567890"

# Kan.bn
kan_base_url: "https://kan.imagineering.cc/api/v1"
kan_api_key: ""

# Outline
outline_base_url: "https://outline.imagineering.cc/api"
outline_api_key: ""

# Radicale (optional — calendar/contacts)
radicale_base_url: "https://dav.imagineering.cc"
radicale_username: "pm-agent"
radicale_password: ""

# Bot config
playwright_enabled: "false"
bot_name: "Dreamfinder"
log_level: "info"
