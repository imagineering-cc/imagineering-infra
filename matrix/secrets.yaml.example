# Matrix homeserver secrets
# Copy to secrets.yaml, fill in values, then encrypt:
#   cp secrets.yaml.example secrets.yaml
#   # Edit secrets.yaml with real values
#   sops -e -i secrets.yaml

matrix_server_name: imagineering.cc
registration_token: CHANGE_ME

# Relay appservice tokens (generate each with: python -c "import secrets; print(secrets.token_hex(32))")
relay_as_token: CHANGE_ME
relay_hs_token: CHANGE_ME

# Room IDs for relay bot
portal_rooms: "!whatsapp-portal:imagineering.cc=WhatsApp,!signal-portal:imagineering.cc=Signal"
hub_room_id: "!hub-room:imagineering.cc"

# Double puppet mapping (localparts, semicolon-separated per user)
# relay_double_puppets: "nick=signal_<uuid>,whatsapp_<phone>"
relay_double_puppets: ""

# Log level for relay bot (INFO or DEBUG)
relay_log_level: INFO

# === Backup integration ===
#
# Matrix admin token: access token for a user with admin powers on the
# homeserver. Used by /opt/scripts/backup.sh to send `!admin server
# backup-database` to the #admins room before each nightly Continuwuity
# backup. Get it from Element → Settings → Help & About → Advanced → Access
# token, signed in as the admin user.
matrix_admin_token: CHANGE_ME

# Age recipient (public key) used to encrypt the Continuwuity tarball
# before pushing to imagineering-backups. Defaults to Nick's existing SOPS
# recipient — change only if you want a dedicated backup key. Find your
# SOPS recipient with: age-keygen -y ~/.config/sops/age/keys.txt
backup_age_recipient: age1mkelwyppmll44ehjnarunmtamcxpee7jljyl475mlvxma7dm4f3q6lnmks
