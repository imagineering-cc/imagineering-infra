# claude-shim configuration. Copy to `.env` on the host (never commit .env).

# Max-plan auth for headless Claude Code. Mint with `claude setup-token` on the
# Max account you want these calls billed against (it owns the weekly turn
# quota). This is the PREFERRED auth, same as claudius.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional fallback if you have no Max token — metered Anthropic API. The shim
# boots if EITHER this or the OAuth token is set. Leave blank to force Max-plan.
# ANTHROPIC_API_KEY=

# Optional tuning.
# PORT=8088
# SHIM_DEFAULT_MODEL=haiku
# SHIM_TIMEOUT_MS=60000
