matrix.imagineering.cc {
    handle /.well-known/matrix/server {
        header Content-Type "application/json"
        respond `{"m.server": "matrix.imagineering.cc:443"}`
    }
    handle /.well-known/matrix/client {
        header Content-Type "application/json"
        header Access-Control-Allow-Origin "*"
        respond `{"m.homeserver": {"base_url": "https://matrix.imagineering.cc"}}`
    }
    handle /mautrix-discord/* {
        reverse_proxy localhost:29334
    }
    handle {
        reverse_proxy localhost:8008
    }
}

imagineering.cc {
    handle /.well-known/matrix/server {
        header Content-Type "application/json"
        respond `{"m.server": "matrix.imagineering.cc:443"}`
    }
    handle /.well-known/matrix/client {
        header Content-Type "application/json"
        header Access-Control-Allow-Origin "*"
        respond `{"m.homeserver": {"base_url": "https://matrix.imagineering.cc"}}`
    }
    handle_path /api/contact {
        reverse_proxy localhost:3014
    }
    @stage_guest {
        path /stage /api/join /api/whoami /api/profile /api/search /api/queue /api/upvote /api/votes /api/visuals /api/gesture /api/events
    }
    handle @stage_guest {
        reverse_proxy 100.71.8.40:3000
    }
    handle {
        root * /srv/site
        file_server
    }
}

