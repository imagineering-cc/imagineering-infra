# Google Cloud Storage credentials for backups
# Uses GCE instance service account (no explicit credentials needed)
#
# Copy to secrets.yaml and encrypt with: sops -e -i secrets.yaml

# GCS bucket name
gcs_bucket: imagineering-backups

# GCP project ID
gcs_project: your-project-id

# Telegram alerts for health checks (optional)
# Create a bot via @BotFather, add to your alert group
telegram_bot_token: ""
telegram_chat_id: ""
telegram_thread_id: ""
